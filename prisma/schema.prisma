// Seyaa Order Management — data model
//
// The key design idea: jewellery products have wildly different specs
// (a ring has a ring-size; a chain has a length; a diamond ring has
// clarity/cut/carat). Instead of hardcoding columns, attributes are
// defined as DATA. Each ProductType declares which attributes apply,
// and each OrderItem stores the chosen values. Adding a new spec later
// (e.g. "engraving") never requires a schema migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prototype: SQLite. For a shared cloud DB across all 4 regions,
  // change provider to "postgresql" and point DATABASE_URL at it.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A business location / market.
model Region {
  id        String     @id @default(cuid())
  name      String     @unique // USA, Dubai, Hong Kong, India
  currency  String              // USD, AED, HKD, INR
  customers Customer[]
  orders    Order[]
  users     User[]
}

// You and your colleagues who register orders.
model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  role     String  @default("staff") // admin | staff
  region   Region? @relation(fields: [regionId], references: [id])
  regionId String?
  orders   Order[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  notes     String?
  region    Region?  @relation(fields: [regionId], references: [id])
  regionId  String?
  orders    Order[]
  createdAt DateTime @default(now())
}

// How a value for an attribute is captured in the form.
// SELECT = dropdown (uses options), NUMBER = numeric input, TEXT = free text.
model Attribute {
  id          String             @id @default(cuid())
  name        String             @unique // "Gold Color", "Diamond Clarity"...
  inputType   String             @default("SELECT") // SELECT | NUMBER | TEXT
  unit        String?            // "ct", "mm", "g" ...
  options     AttributeOption[]
  productLink ProductAttribute[]
  itemSpecs   ItemSpec[]
}

// Allowed values for a SELECT attribute (prevents "18k" vs "18K" typos).
model AttributeOption {
  id          String    @id @default(cuid())
  value       String
  sortOrder   Int       @default(0)
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeId String
}

// Ring, Necklace, Bracelet, Earrings, Pendant, Chain...
model ProductType {
  id         String             @id @default(cuid())
  name       String             @unique
  attributes ProductAttribute[]
  orderItems OrderItem[]
}

// Which attributes apply to which product type (and are they required).
model ProductAttribute {
  id            String      @id @default(cuid())
  productType   ProductType @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  productTypeId String
  attribute     Attribute   @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeId   String
  required      Boolean     @default(false)
  sortOrder     Int         @default(0)

  @@unique([productTypeId, attributeId])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  status      String      @default("NEW") // NEW | CONFIRMED | IN_PRODUCTION | QC | SHIPPED | DELIVERED | CANCELLED
  salesPerson String?     // who the order came from
  notes       String?
  customer    Customer    @relation(fields: [customerId], references: [id])
  customerId  String
  region      Region      @relation(fields: [regionId], references: [id])
  regionId    String
  createdBy   User?       @relation(fields: [createdById], references: [id])
  createdById String?
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id            String      @id @default(cuid())
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String
  productType   ProductType @relation(fields: [productTypeId], references: [id])
  productTypeId String
  quantity      Int         @default(1)
  price         Float?
  specs         ItemSpec[]
}

// The chosen value for one attribute on one order item.
// e.g. attribute "Diamond Size" -> value "1.50" (unit ct)
model ItemSpec {
  id          String    @id @default(cuid())
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId String
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  attributeId String
  value       String
}
